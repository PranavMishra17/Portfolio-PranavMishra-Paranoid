# Copy to .env.local (gitignored) for local dev.
# In production (Vercel), set this in Project Settings -> Environment Variables.
#
# The displayed view count is OFFSET + (raw API counter). Keeping the offset
# out of the repo means casual repo readers can't see the baseline. Anyone
# digging the minified production bundle can still recover it; this is by
# design accepted as a tradeoff.
REACT_APP_VIEW_OFFSET=1240

# Prompt Patrol global leaderboard.
# Create a free pantry at https://getpantry.cloud — they email you a UUID.
# Drop the UUID here and pick any string for the basket name.
# In production (Vercel) set both vars under Project Settings -> Environment Variables.
REACT_APP_PANTRY_ID=
REACT_APP_PANTRY_BASKET=prompt-patrol-scores
